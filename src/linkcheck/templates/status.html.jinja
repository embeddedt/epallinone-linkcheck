<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Easy Peasy Link Check Status</title>
<style>
  body { font-family: Georgia, "Times New Roman", Times, serif; padding: 2rem 1rem 4rem; }
  img.logo { display: block; margin: 0 auto 1rem; }
  h1, h2 { text-align: center; font-weight: normal; }
  h1 { margin-bottom: 0.2rem; }
  h2 { margin-top: 0; font-size: 1.1rem; }
  p.generated-at { text-align: center; margin-bottom: 2rem; }
  table { border-collapse: collapse; width: 100%; margin-bottom: 1.5rem; }
  th, td { border: 1px solid #999; padding: 4px 8px; text-align: left; vertical-align: top; overflow-wrap: break-word; }
  #problem-table, #watch-table { table-layout: fixed; }
  th { background: #eee; }
  tbody.course-group .group-header td { background: #f5f5f5; font-weight: bold; border-top: 2px solid #999; cursor: pointer; user-select: none; }
  tbody.course-group .group-header td::before { content: "\25be"; display: inline-block; margin-right: 0.5rem; }
  tbody.course-group.collapsed .group-header td::before { content: "\25b8"; }
</style>
</head>
<body>

<img class="logo" src="assets/ep-logo.jpg" width="90" height="90" alt="Easy Peasy All-in-One Homeschool logo">
<h1>Easy Peasy All-in-One Homeschool</h1>
<h2>Link Check Status</h2>
<p class="generated-at">Generated <time class="relative-time" datetime="{{ generated_at }}">{{ generated_at }}</time></p>

<h3>Site summary</h3>
<table>
  <thead>
    <tr>
      <th>Site</th>
      <th>Total</th>
      <th>OK</th>
      <th>Broken</th>
      <th>Unreachable</th>
      <th>Pending</th>
      <th>Watching</th>
    </tr>
  </thead>
  <tbody>
    {% for s in summaries %}
    <tr>
      <td>{{ s.slug }}</td>
      <td>{{ s.total }}</td>
      <td>{{ s.ok }}</td>
      <td>{{ s.broken }}</td>
      <td>{{ s.unreachable }}</td>
      <td>{{ s.pending }}</td>
      <td>{{ s.watching }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

{% if problem_groups or watch_groups %}
<p class="instructions">
  Each course below is a collapsible group &mdash; click a course's header row to
  expand or collapse it (your choice is remembered on this device), or use
  Expand&nbsp;all / Collapse&nbsp;all below. In the tables, use the search box to
  filter by URL, host, or page title, and the status buttons to show only
  Broken or only Unreachable links. Click a course title to open that course
  page, or the link in the "Link name" column to jump to where the broken
  link appears on the page.
</p>
<p class="group-controls">
  <button type="button" id="expand-all">Expand all</button>
  <button type="button" id="collapse-all">Collapse all</button>
</p>
{% endif %}

<h3>Broken / unreachable links ({{ problem_links|length }})</h3>
{% if not problem_links %}
<p>No broken or unreachable links.</p>
{% else %}
<p>
  <input type="search" id="search" placeholder="Filter by URL, host, or page title">
  <button type="button" class="filter-btn active" data-status="all">All</button>
  <button type="button" class="filter-btn" data-status="broken">Broken</button>
  <button type="button" class="filter-btn" data-status="unreachable">Unreachable</button>
</p>
<table id="problem-table">
  <colgroup>
    <col style="width: 8%">
    <col style="width: 10%">
    <col style="width: 27%">
    <col style="width: 35%">
    <col style="width: 7%">
    <col style="width: 13%">
  </colgroup>
  <thead>
    <tr>
      <th>Status</th>
      <th>Reason</th>
      <th>Link name</th>
      <th>Broken link</th>
      <th>Failures</th>
      <th></th>
    </tr>
  </thead>
  {% for group in problem_groups %}
  <tbody class="course-group" data-group-key="problem:{{ group.page_url }}">
    <tr class="group-header">
      <td colspan="6">{{ group.site_slug }}: <a href="{{ group.page_url }}" target="_blank" rel="noopener noreferrer">{{ group.page_title }}</a> ({{ group.entries|length }})</td>
    </tr>
    {% for entry in group.entries %}
    <tr class="row" data-status="{{ entry.link.status }}"
        data-search="{{ (entry.link.url ~ ' ' ~ entry.link.host ~ ' ' ~ group.page_title ~ ' ' ~ (entry.link_text or '') ~ ' ' ~ (entry.context_before or '') ~ ' ' ~ (entry.context_after or ''))|lower }}">
      <td>{{ entry.link.status }}</td>
      <td>{{ entry.link|outcome }}</td>
      <td>
        {% if entry.link_text %}&ldquo;{% if entry.context_before %}&hellip;{{ entry.context_before }} {% endif %}<strong>{{ entry.link_text }}</strong>{% if entry.context_after %} {{ entry.context_after }}&hellip;{% endif %}&rdquo;{% endif %}
        (<a href="{{ found_on_href(group, entry) }}" target="_blank" rel="noopener noreferrer">{% if entry.day_context %}{{ entry.day_label or entry.day_context }}{% else %}view on page{% endif %}</a>)
      </td>
      <td><a href="{{ entry.link.url }}" target="_blank" rel="noopener noreferrer">{{ entry.link.url }}</a></td>
      <td>{{ entry.link.consecutive_failures }}</td>
      <td>
        {% if entry.link.last_checked_at %}
        <time class="relative-time" datetime="{{ entry.link.last_checked_at }}">{{ entry.link.last_checked_at }}</time>
        {% else %}
        never
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
  {% endfor %}
</table>
{% endif %}

{% if watch_links %}
<h3>Watching ({{ watch_links|length }})</h3>
<p>
  Failed at least one check but not confirmed broken/unreachable yet - could be a
  transient blip. Will be rechecked automatically; only moves into the list above
  if it keeps failing.
</p>
<table id="watch-table">
  <colgroup>
    <col style="width: 8%">
    <col style="width: 10%">
    <col style="width: 27%">
    <col style="width: 35%">
    <col style="width: 7%">
    <col style="width: 13%">
  </colgroup>
  <thead>
    <tr>
      <th>Status</th>
      <th>Reason</th>
      <th>Link name</th>
      <th>Link</th>
      <th>Failures</th>
      <th>Next check</th>
    </tr>
  </thead>
  {% for group in watch_groups %}
  <tbody class="course-group" data-group-key="watch:{{ group.page_url }}">
    <tr class="group-header">
      <td colspan="6">{{ group.site_slug }}: <a href="{{ group.page_url }}" target="_blank" rel="noopener noreferrer">{{ group.page_title }}</a> ({{ group.entries|length }})</td>
    </tr>
    {% for entry in group.entries %}
    <tr>
      <td class="status-watching">watching</td>
      <td>{{ entry.link|outcome }}</td>
      <td>
        {% if entry.link_text %}&ldquo;{% if entry.context_before %}&hellip;{{ entry.context_before }} {% endif %}<strong>{{ entry.link_text }}</strong>{% if entry.context_after %} {{ entry.context_after }}&hellip;{% endif %}&rdquo;{% endif %}
        (<a href="{{ found_on_href(group, entry) }}" target="_blank" rel="noopener noreferrer">{% if entry.day_context %}{{ entry.day_label or entry.day_context }}{% else %}view on page{% endif %}</a>)
      </td>
      <td><a href="{{ entry.link.url }}" target="_blank" rel="noopener noreferrer">{{ entry.link.url }}</a></td>
      <td>{{ entry.link.consecutive_failures }}</td>
      <td><time class="relative-time" datetime="{{ entry.link.next_check_at }}">{{ entry.link.next_check_at }}</time></td>
    </tr>
    {% endfor %}
  </tbody>
  {% endfor %}
</table>
{% endif %}

<script>
(function () {
  var search = document.getElementById("search");
  var buttons = document.querySelectorAll(".filter-btn");
  var groups = document.querySelectorAll(".course-group");
  var activeStatus = "all";

  function rowMatchesFilter(row) {
    if (!row.classList.contains("row")) return true;
    var q = (search && search.value || "").toLowerCase();
    var matchesStatus = activeStatus === "all" || row.dataset.status === activeStatus;
    var matchesSearch = !q || row.dataset.search.indexOf(q) !== -1;
    return matchesStatus && matchesSearch;
  }

  function refreshVisibility() {
    groups.forEach(function (group) {
      var collapsed = group.classList.contains("collapsed");
      var anyMatch = false;
      group.querySelectorAll("tr:not(.group-header)").forEach(function (row) {
        var matches = rowMatchesFilter(row);
        if (matches) anyMatch = true;
        row.style.display = matches && !collapsed ? "" : "none";
      });
      group.style.display = anyMatch ? "" : "none";
    });
  }

  var STORAGE_KEY = "linkcheck.collapsedGroups";

  function loadCollapsedKeys() {
    try {
      return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]"));
    } catch (e) {
      return new Set();
    }
  }

  function saveCollapsedKeys() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(collapsedKeys)));
    } catch (e) {}
  }

  var collapsedKeys = loadCollapsedKeys();

  function setGroupCollapsed(group, collapsed) {
    group.classList.toggle("collapsed", collapsed);
    var key = group.dataset.groupKey;
    if (!key) return;
    if (collapsed) collapsedKeys.add(key);
    else collapsedKeys.delete(key);
  }

  groups.forEach(function (group) {
    var key = group.dataset.groupKey;
    if (key && collapsedKeys.has(key)) group.classList.add("collapsed");

    var header = group.querySelector(".group-header");
    if (!header) return;
    header.addEventListener("click", function (event) {
      if (event.target.closest("a")) return;
      setGroupCollapsed(group, !group.classList.contains("collapsed"));
      saveCollapsedKeys();
      refreshVisibility();
    });
  });

  var expandAllBtn = document.getElementById("expand-all");
  var collapseAllBtn = document.getElementById("collapse-all");

  function setAllCollapsed(collapsed) {
    groups.forEach(function (group) { setGroupCollapsed(group, collapsed); });
    saveCollapsedKeys();
    refreshVisibility();
  }

  if (expandAllBtn) expandAllBtn.addEventListener("click", function () { setAllCollapsed(false); });
  if (collapseAllBtn) collapseAllBtn.addEventListener("click", function () { setAllCollapsed(true); });

  refreshVisibility();

  if (search) {
    search.addEventListener("input", refreshVisibility);
    buttons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        buttons.forEach(function (b) { b.classList.remove("active"); });
        btn.classList.add("active");
        activeStatus = btn.dataset.status;
        refreshVisibility();
      });
    });
  }

  function formatRelative(iso) {
    var diffMs = new Date(iso).getTime() - Date.now();
    var sec = Math.round(Math.abs(diffMs) / 1000);
    var units = [["day", 86400], ["hour", 3600], ["minute", 60], ["second", 1]];
    for (var i = 0; i < units.length; i++) {
      var amount = Math.floor(sec / units[i][1]);
      if (amount >= 1 || i === units.length - 1) {
        var label = units[i][0] + (amount === 1 ? "" : "s");
        return diffMs >= 0 ? "in " + amount + " " + label : amount + " " + label + " ago";
      }
    }
  }

  document.querySelectorAll(".relative-time").forEach(function (el) {
    el.textContent = formatRelative(el.getAttribute("datetime"));
    el.title = el.getAttribute("datetime");
  });
})();
</script>

</body>
</html>
