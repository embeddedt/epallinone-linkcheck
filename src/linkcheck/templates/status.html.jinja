<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Easy Peasy Link Check Status</title>
<style>
  body { font-family: Georgia, "Times New Roman", Times, serif; padding: 2rem 1rem 4rem; }
  img.logo { display: block; margin: 0 auto 1rem; }
  h1, h2 { text-align: center; font-weight: normal; }
  h1 { margin-bottom: 0.2rem; }
  h2 { margin-top: 0; font-size: 1.1rem; }
  table { border-collapse: collapse; width: 100%; margin-bottom: 1.5rem; }
  th, td { border: 1px solid #999; padding: 4px 8px; text-align: left; vertical-align: top; overflow-wrap: break-word; }
  #problem-table, #watch-table { table-layout: fixed; }
  th { background: #eee; }
  tbody.course-group .group-header td { background: #f5f5f5; font-weight: bold; border-top: 2px solid #999; cursor: pointer; user-select: none; }
  tbody.course-group .group-header td::before { content: "\25be"; display: inline-block; margin-right: 0.5rem; }
  tbody.course-group.collapsed .group-header td::before { content: "\25b8"; }
  .mark-done-btn, .undo-done-btn { font-size: 0.85rem; margin-top: 0.25rem; }
  #marked-done-table tbody tr { color: #666; }
</style>
</head>
<body>

<img class="logo" src="assets/ep-logo.jpg" width="90" height="90" alt="Easy Peasy All-in-One Homeschool logo">
<h1>Easy Peasy All-in-One Homeschool</h1>
<h2>Link Check Status</h2>

{% if problem_groups or watch_groups %}
<p class="instructions">
  Each course below is a collapsible group &mdash; click a course's header row to
  expand or collapse it (your choice is remembered on this device), or use
  Expand&nbsp;all / Collapse&nbsp;all below. In the tables, use the search box to
  filter by URL, host, or page title, and the status buttons to show only
  Broken or only Unreachable links. Click a course title to open that course
  page, or the link in the "Link name" column to jump to where the broken
  link appears on the page.
</p>
<p class="group-controls">
  <button type="button" id="expand-all">Expand all</button>
  <button type="button" id="collapse-all">Collapse all</button>
</p>
{% endif %}

<h3>Broken / unreachable links (<span id="problem-count">{{ problem_links|length }}</span>)</h3>
{% if not problem_links %}
<p>No broken or unreachable links.</p>
{% else %}
<p>
  <input type="search" id="search" placeholder="Filter by URL, host, or page title">
  <button type="button" class="filter-btn active" data-status="all">All</button>
  <button type="button" class="filter-btn" data-status="broken">Broken</button>
  <button type="button" class="filter-btn" data-status="unreachable">Unreachable</button>
</p>
<table id="problem-table">
  <colgroup>
    <col style="width: 8%">
    <col style="width: 10%">
    <col style="width: 27%">
    <col style="width: 35%">
    <col style="width: 7%">
    <col style="width: 13%">
  </colgroup>
  <thead>
    <tr>
      <th>Status</th>
      <th>Reason</th>
      <th>Link name</th>
      <th>Broken link</th>
      <th>Failures</th>
      <th></th>
    </tr>
  </thead>
  {% for group in problem_groups %}
  <tbody class="course-group" data-group-key="problem:{{ group.page_url }}">
    <tr class="group-header">
      <td colspan="6">{{ group.site_slug }}: <a href="{{ group.page_url }}" target="_blank" rel="noopener noreferrer">{{ group.page_title }}</a> (<span class="group-count" data-singular="broken link">{{ group.entries|length|pluralize('broken link') }}</span>){% if group.last_crawled_at %} &mdash; last crawled <time class="relative-time" datetime="{{ group.last_crawled_at }}">{{ group.last_crawled_at }}</time>{% endif %}</td>
    </tr>
    {% for entry in group.entries %}
    <tr class="row" data-status="{{ entry.link.status }}" data-link-id="{{ entry.link.id }}"
        data-course="{{ group.site_slug }}: {{ group.page_title }}"
        data-search="{{ (entry.link.url ~ ' ' ~ entry.link.host ~ ' ' ~ group.page_title ~ ' ' ~ (entry.link_text or '') ~ ' ' ~ (entry.context_before or '') ~ ' ' ~ (entry.context_after or ''))|lower }}">
      <td>{{ entry.link.status }}</td>
      <td>{{ entry.link|outcome }}</td>
      <td>
        {% if entry.link_text %}&ldquo;{% if entry.context_before %}&hellip;{{ entry.context_before }} {% endif %}<strong>{{ entry.link_text }}</strong>{% if entry.context_after %} {{ entry.context_after }}&hellip;{% endif %}&rdquo;{% else %}<em>no visible link text &mdash; check page source</em>{% endif %}
        (<a href="{{ found_on_href(group, entry) }}" target="_blank" rel="noopener noreferrer">{% if entry.day_context %}jump to {{ entry.day_label or entry.day_context }}{% else %}view on page{% endif %}</a>)
      </td>
      <td><a href="{{ entry.link.url }}" target="_blank" rel="noopener noreferrer">{{ entry.link.url }}</a></td>
      <td>{{ entry.link.consecutive_failures }}</td>
      <td>
        {% if entry.link.last_checked_at %}
        <time class="relative-time" datetime="{{ entry.link.last_checked_at }}">{{ entry.link.last_checked_at }}</time>
        {% else %}
        never
        {% endif %}
        <br><button type="button" class="mark-done-btn" data-link-id="{{ entry.link.id }}">Mark done</button>
      </td>
    </tr>
    {% endfor %}
  </tbody>
  {% endfor %}
</table>
{% endif %}

{% if watch_links %}
<h3>Watching ({{ watch_links|length }})</h3>
<p>
  Failed at least one check but not confirmed broken/unreachable yet - could be a
  transient blip. Will be rechecked automatically; only moves into the list above
  if it keeps failing.
</p>
<table id="watch-table">
  <colgroup>
    <col style="width: 8%">
    <col style="width: 10%">
    <col style="width: 27%">
    <col style="width: 35%">
    <col style="width: 7%">
    <col style="width: 13%">
  </colgroup>
  <thead>
    <tr>
      <th>Status</th>
      <th>Reason</th>
      <th>Link name</th>
      <th>Link</th>
      <th>Failures</th>
      <th>Next check</th>
    </tr>
  </thead>
  {% for group in watch_groups %}
  <tbody class="course-group" data-group-key="watch:{{ group.page_url }}">
    <tr class="group-header">
      <td colspan="6">{{ group.site_slug }}: <a href="{{ group.page_url }}" target="_blank" rel="noopener noreferrer">{{ group.page_title }}</a> ({{ group.entries|length|pluralize('watched link') }}){% if group.last_crawled_at %} &mdash; last crawled <time class="relative-time" datetime="{{ group.last_crawled_at }}">{{ group.last_crawled_at }}</time>{% endif %}</td>
    </tr>
    {% for entry in group.entries %}
    <tr>
      <td class="status-watching">watching</td>
      <td>{{ entry.link|outcome }}</td>
      <td>
        {% if entry.link_text %}&ldquo;{% if entry.context_before %}&hellip;{{ entry.context_before }} {% endif %}<strong>{{ entry.link_text }}</strong>{% if entry.context_after %} {{ entry.context_after }}&hellip;{% endif %}&rdquo;{% else %}<em>no visible link text &mdash; check page source</em>{% endif %}
        (<a href="{{ found_on_href(group, entry) }}" target="_blank" rel="noopener noreferrer">{% if entry.day_context %}jump to {{ entry.day_label or entry.day_context }}{% else %}view on page{% endif %}</a>)
      </td>
      <td><a href="{{ entry.link.url }}" target="_blank" rel="noopener noreferrer">{{ entry.link.url }}</a></td>
      <td>{{ entry.link.consecutive_failures }}</td>
      <td><time class="relative-time" datetime="{{ entry.link.next_check_at }}">{{ entry.link.next_check_at }}</time></td>
    </tr>
    {% endfor %}
  </tbody>
  {% endfor %}
</table>
{% endif %}

<div id="marked-done-wrapper" style="display: none">
<h3>Marked as done</h3>
<p>
  Links you've dismissed on this device. They're hidden from the list above; use
  Undo to bring one back.
</p>
<table id="marked-done-table">
  <colgroup>
    <col style="width: 14%">
    <col style="width: 7%">
    <col style="width: 9%">
    <col style="width: 22%">
    <col style="width: 30%">
    <col style="width: 8%">
    <col style="width: 10%">
  </colgroup>
  <thead>
    <tr>
      <th>Course(s)</th>
      <th>Status</th>
      <th>Reason</th>
      <th>Link name</th>
      <th>Broken link</th>
      <th>Failures</th>
      <th></th>
    </tr>
  </thead>
  <tbody id="marked-done-tbody"></tbody>
</table>
</div>

{% if blacklist_rules %}
<h3>Excluded by configuration</h3>
<p>Links matching a rule below are never checked and never appear in the lists above (see <code>config.py</code>).</p>
<table id="blacklist-table">
  <thead>
    <tr>
      <th>Rule</th>
      <th>Type</th>
      <th>Values</th>
      <th>Why</th>
    </tr>
  </thead>
  <tbody>
    {% for rule in blacklist_rules %}
    <tr>
      <td>{{ rule.label }}</td>
      <td>{{ rule.kind }}</td>
      <td>{{ rule.values|sort|join(', ') }}</td>
      <td>{{ rule.reason }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<script>
(function () {
  var search = document.getElementById("search");
  var buttons = document.querySelectorAll(".filter-btn");
  var groups = document.querySelectorAll(".course-group");
  var activeStatus = "all";

  function rowMatchesFilter(row) {
    if (!row.classList.contains("row")) return true;
    if (row.dataset.linkId && doneIds.has(row.dataset.linkId)) return false;
    var q = (search && search.value || "").toLowerCase();
    var matchesStatus = activeStatus === "all" || row.dataset.status === activeStatus;
    var matchesSearch = !q || row.dataset.search.indexOf(q) !== -1;
    return matchesStatus && matchesSearch;
  }

  function refreshVisibility() {
    groups.forEach(function (group) {
      var collapsed = group.classList.contains("collapsed");
      var anyMatch = false;
      group.querySelectorAll("tr:not(.group-header)").forEach(function (row) {
        var matches = rowMatchesFilter(row);
        if (matches) anyMatch = true;
        row.style.display = matches && !collapsed ? "" : "none";
      });
      group.style.display = anyMatch ? "" : "none";
    });
  }

  var STORAGE_KEY = "linkcheck.collapsedGroups";

  function loadCollapsedKeys() {
    try {
      return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]"));
    } catch (e) {
      return new Set();
    }
  }

  function saveCollapsedKeys() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(collapsedKeys)));
    } catch (e) {}
  }

  var collapsedKeys = loadCollapsedKeys();

  var DONE_STORAGE_KEY = "linkcheck.markedDone";

  function loadDoneIds() {
    try {
      return new Set(JSON.parse(localStorage.getItem(DONE_STORAGE_KEY) || "[]"));
    } catch (e) {
      return new Set();
    }
  }

  function saveDoneIds() {
    try {
      localStorage.setItem(DONE_STORAGE_KEY, JSON.stringify(Array.from(doneIds)));
    } catch (e) {}
  }

  var doneIds = loadDoneIds();
  var problemTable = document.getElementById("problem-table");
  var doneTbody = document.getElementById("marked-done-tbody");
  var doneWrapper = document.getElementById("marked-done-wrapper");

  function renderDoneSection() {
    if (!doneTbody) return;
    doneTbody.innerHTML = "";
    var pruned = false;
    doneIds.forEach(function (id) {
      var matches = problemTable
        ? problemTable.querySelectorAll('tr.row[data-link-id="' + id + '"]')
        : [];
      if (!matches.length) {
        doneIds.delete(id);
        pruned = true;
        return;
      }
      var courses = Array.from(new Set(Array.from(matches).map(function (row) { return row.dataset.course; })));
      var clone = matches[0].cloneNode(true);
      clone.classList.remove("row");
      clone.removeAttribute("style");

      var courseCell = document.createElement("td");
      courseCell.textContent = courses.join(", ");
      clone.insertBefore(courseCell, clone.firstChild);

      var lastCell = clone.lastElementChild;
      lastCell.innerHTML = "";
      var undoBtn = document.createElement("button");
      undoBtn.type = "button";
      undoBtn.className = "undo-done-btn";
      undoBtn.dataset.linkId = id;
      undoBtn.textContent = "Undo";
      lastCell.appendChild(undoBtn);

      doneTbody.appendChild(clone);
    });
    if (pruned) saveDoneIds();
    if (doneWrapper) doneWrapper.style.display = doneTbody.children.length ? "" : "none";
  }

  function pluralize(count, singular) {
    return count + " " + (count === 1 ? singular : singular + "s");
  }

  function updateGroupCounts() {
    groups.forEach(function (group) {
      var span = group.querySelector(".group-count");
      if (!span) return;
      var remaining = 0;
      group.querySelectorAll("tr.row[data-link-id]").forEach(function (row) {
        if (!doneIds.has(row.dataset.linkId)) remaining++;
      });
      span.textContent = pluralize(remaining, span.dataset.singular);
    });

    var problemCount = document.getElementById("problem-count");
    if (problemTable && problemCount) {
      // problem_links (and this heading) count unique links, not page occurrences -
      // a link on multiple course pages produces one row per page but must only count once.
      var remainingIds = new Set();
      problemTable.querySelectorAll("tr.row[data-link-id]").forEach(function (row) {
        if (!doneIds.has(row.dataset.linkId)) remainingIds.add(row.dataset.linkId);
      });
      problemCount.textContent = remainingIds.size;
    }
  }

  if (problemTable) {
    problemTable.addEventListener("click", function (event) {
      var btn = event.target.closest(".mark-done-btn");
      if (!btn) return;
      doneIds.add(btn.dataset.linkId);
      saveDoneIds();
      refreshVisibility();
      renderDoneSection();
      updateGroupCounts();
    });
  }

  if (doneTbody) {
    doneTbody.addEventListener("click", function (event) {
      var btn = event.target.closest(".undo-done-btn");
      if (!btn) return;
      doneIds.delete(btn.dataset.linkId);
      saveDoneIds();
      refreshVisibility();
      renderDoneSection();
      updateGroupCounts();
    });
  }

  function setGroupCollapsed(group, collapsed) {
    group.classList.toggle("collapsed", collapsed);
    var key = group.dataset.groupKey;
    if (!key) return;
    if (collapsed) collapsedKeys.add(key);
    else collapsedKeys.delete(key);
  }

  groups.forEach(function (group) {
    var key = group.dataset.groupKey;
    if (key && collapsedKeys.has(key)) group.classList.add("collapsed");

    var header = group.querySelector(".group-header");
    if (!header) return;
    header.addEventListener("click", function (event) {
      if (event.target.closest("a")) return;
      setGroupCollapsed(group, !group.classList.contains("collapsed"));
      saveCollapsedKeys();
      refreshVisibility();
    });
  });

  var expandAllBtn = document.getElementById("expand-all");
  var collapseAllBtn = document.getElementById("collapse-all");

  function setAllCollapsed(collapsed) {
    groups.forEach(function (group) { setGroupCollapsed(group, collapsed); });
    saveCollapsedKeys();
    refreshVisibility();
  }

  if (expandAllBtn) expandAllBtn.addEventListener("click", function () { setAllCollapsed(false); });
  if (collapseAllBtn) collapseAllBtn.addEventListener("click", function () { setAllCollapsed(true); });

  renderDoneSection();
  updateGroupCounts();
  refreshVisibility();

  if (search) {
    search.addEventListener("input", refreshVisibility);
    buttons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        buttons.forEach(function (b) { b.classList.remove("active"); });
        btn.classList.add("active");
        activeStatus = btn.dataset.status;
        refreshVisibility();
      });
    });
  }

  function formatRelative(iso) {
    var diffMs = new Date(iso).getTime() - Date.now();
    var sec = Math.round(Math.abs(diffMs) / 1000);
    var units = [["day", 86400], ["hour", 3600], ["minute", 60], ["second", 1]];
    for (var i = 0; i < units.length; i++) {
      var amount = Math.floor(sec / units[i][1]);
      if (amount >= 1 || i === units.length - 1) {
        var label = units[i][0] + (amount === 1 ? "" : "s");
        return diffMs >= 0 ? "in " + amount + " " + label : amount + " " + label + " ago";
      }
    }
  }

  document.querySelectorAll(".relative-time").forEach(function (el) {
    el.textContent = formatRelative(el.getAttribute("datetime"));
    el.title = el.getAttribute("datetime");
  });
})();
</script>

</body>
</html>
